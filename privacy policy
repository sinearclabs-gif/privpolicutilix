    }
    .section {
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 20px;
      padding: 32px;
      margin-bottom: 24px;
    }
    .section h2 {
      font-size: 20px;
      font-weight: 800;
      color: #fff;
      margin-bottom: 16px;
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .section h2 .icon {
      width: 36px; height: 36px;
      background: rgba(249,115,22,0.15);
      border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      font-size: 18px;
    }
    .section p { color: #94a3b8; font-size: 15px; margin-bottom: 12px; }
    .section p:last-child { margin-bottom: 0; }
    .perm-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 14px;
      margin-top: 8px;
    }
    .perm-card {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 14px;
      padding: 16px 18px;
    }
    .perm-card .perm-name {
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 1px;
      color: #f97316;
      margin-bottom: 4px;
      font-family: monospace;
    }
