    .contact-box a {
      display: inline-block;
      background: #f97316;
      color: #fff;
      padding: 12px 28px;
      border-radius: 12px;
      font-weight: 700;
      font-size: 14px;
    }
    .footer {
      text-align: center;
      color: #475569;
      font-size: 13px;
      margin-top: 40px;
    }
